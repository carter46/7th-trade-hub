APP_NAME="7th Trade Hub"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_DAILY_DAYS=14

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=7th_trade_hub
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Shared hosting: use sync until queue worker is confirmed running
QUEUE_CONNECTION=sync

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

WALLET_PROVIDER=manual
WALLET_PLATFORM_CRYPTO_ADDRESS=

# Platform catalog: prefer DB service_categories / product_types when populated
CATALOG_USE_DB_HIERARCHY=true

# Optional legal contact shown on /legal
# LEGAL_CONTACT_EMAIL=legal@yourdomain.com

# Production admin (php artisan db:seed --class=ProductionSeeder)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=
# ADMIN_NAME=Admin
# ADMIN_USERNAME=admin

# Optional error monitoring (composer require sentry/sentry-laravel)
# SENTRY_LARAVEL_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.2

# Optional Slack alerts for critical errors
# LOG_SLACK_WEBHOOK_URL=

# Comma-separated proxy IPs (Cloudflare, load balancer). Leave empty if not behind a proxy.
# TRUSTED_PROXIES=
